FROM almalinux:latest AS builder
ARG APP_NAME=app
ARG APP_ICON_URL=""
ENV APP_NAME=${APP_NAME}
ENV APP_ICON_URL=${APP_ICON_URL}

WORKDIR /app
COPY app.rpm .

RUN dnf install -y epel-release \
    && dnf update -y \
    && dnf install -y wget \
    && dnf install -y ./app.rpm \
    && dnf clean all -y

# ── AppImage stage ────────────────────────────────────────────────────────────
FROM builder AS appimage

RUN mkdir -p /output \
             /app/AppDir/usr/bin \
             /app/AppDir/usr/share/icons/hicolor/256x256/apps \
             /app/AppDir/usr/share/icons/hicolor/scalable/apps \
             /app/AppDir/usr/share/applications

# Copy the installed binary into AppDir
RUN cp /usr/bin/${APP_NAME} /app/AppDir/usr/bin/${APP_NAME}

# Copy icons — try standard RPM install locations, fall back to APP_ICON_URL
RUN \
  # 256x256 PNG
  if [ -f "/usr/share/icons/hicolor/256x256/apps/${APP_NAME}.png" ]; then \
    cp "/usr/share/icons/hicolor/256x256/apps/${APP_NAME}.png" \
       "/app/AppDir/usr/share/icons/hicolor/256x256/apps/${APP_NAME}.png"; \
  elif [ -f "/usr/share/pixmaps/${APP_NAME}.png" ]; then \
    cp "/usr/share/pixmaps/${APP_NAME}.png" \
       "/app/AppDir/usr/share/icons/hicolor/256x256/apps/${APP_NAME}.png"; \
  elif [ -n "${APP_ICON_URL}" ]; then \
    wget -qO "/app/AppDir/usr/share/icons/hicolor/256x256/apps/${APP_NAME}.png" \
         "${APP_ICON_URL}"; \
  else \
    echo "ERROR: No icon found for ${APP_NAME}" && exit 1; \
  fi && \
  # Scalable SVG (optional — don't fail if absent)
  if [ -f "/usr/share/icons/hicolor/scalable/apps/${APP_NAME}.svg" ]; then \
    cp "/usr/share/icons/hicolor/scalable/apps/${APP_NAME}.svg" \
       "/app/AppDir/usr/share/icons/hicolor/scalable/apps/${APP_NAME}.svg"; \
  elif [ -f "/usr/share/pixmaps/${APP_NAME}.svg" ]; then \
    cp "/usr/share/pixmaps/${APP_NAME}.svg" \
       "/app/AppDir/usr/share/icons/hicolor/scalable/apps/${APP_NAME}.svg"; \
  fi

# Write .desktop file
RUN printf '[Desktop Entry]\nName=%s\nExec=%s %%f\nIcon=%s\nType=Application\nCategories=Development;Science;Education;\nComment=%s\n' \
    "${APP_NAME}" "${APP_NAME}" "${APP_NAME}" "${APP_NAME}" \
    > /app/AppDir/usr/share/applications/${APP_NAME}.desktop

# Download linuxdeploy and GTK plugin
RUN wget -q \
      https://github.com/linuxdeploy/linuxdeploy/releases/download/continuous/linuxdeploy-x86_64.AppImage \
      -O /usr/local/bin/linuxdeploy && \
    chmod +x /usr/local/bin/linuxdeploy

RUN wget -q \
      https://raw.githubusercontent.com/linuxdeploy/linuxdeploy-plugin-gtk/master/linuxdeploy-plugin-gtk.sh \
      -O /usr/local/bin/linuxdeploy-plugin-gtk.sh && \
    chmod +x /usr/local/bin/linuxdeploy-plugin-gtk.sh

WORKDIR /app

ENV APPIMAGE_EXTRACT_AND_RUN=1
ENV ARCH=x86_64

# NO_STRIP=1 avoids strip failures caused by the toolchain version mismatch
# between linuxdeploy's bundled binutils and AlmaLinux's RELR-relocation libs.
# The RPM-installed libraries are already stripped by the distro build anyway.
RUN NO_STRIP=1 \
    DEPLOY_GTK_VERSION=4 \
    OUTPUT=/output/${APP_NAME}-x86_64.AppImage \
    /usr/local/bin/linuxdeploy \
      --appdir AppDir \
      --desktop-file AppDir/usr/share/applications/${APP_NAME}.desktop \
      --icon-file AppDir/usr/share/icons/hicolor/256x256/apps/${APP_NAME}.png \
      --plugin gtk \
      --output appimage && \
    test -f /output/${APP_NAME}-x86_64.AppImage
